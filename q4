#include <stdio.h>
#include <stdlib.h>

#define ST_MAX 100

int input_dimensions(int *rows, int *cols);
int input_menu(int *type);
int input_matrix(int **matrix, int rows, int cols);
void output_matrix(int **matrix, int rows, int cols);

void find_rows_max(int **matrix, int rows, int cols, int *res);
void find_cols_min(int **matrix, int rows, int cols, int *res);
void output_array(const int *arr, int len);

void free_matrix(int **matrix, int rows, int type, int *data3, int *data4);

int main(void) {
    int type;
    if (input_menu(&type) != 0) {
        printf("n/a");
        return 0;
    }

    int rows, cols;
    if (input_dimensions(&rows, &cols) != 0) {
        printf("n/a");
        return 0;
    }

    if (type == 1 && (rows > ST_MAX || cols > ST_MAX)) {
        printf("n/a");
        return 0;
    }

    int **matrix = NULL;
    int static_arr[ST_MAX][ST_MAX];
    int *static_ptrs[ST_MAX];
    int *data3 = NULL;
    int *data4 = NULL;

    if (type == 1) {
        for (int i = 0; i < rows; i++) {
            static_ptrs[i] = static_arr[i];
        }
        matrix = static_ptrs;
    } else if (type == 2) {
        matrix = (int **)malloc(rows * sizeof(int *));
        if (matrix == NULL) { printf("n/a"); return 0; }
        for (int i = 0; i < rows; i++) {
            matrix[i] = (int *)malloc(cols * sizeof(int));
            if (matrix[i] == NULL) {
                free_matrix(matrix, i, 2, data3, data4);
                printf("n/a");
                return 0;
            }
        }
    } else if (type == 3) {
        matrix = (int **)malloc(rows * sizeof(int *));
        data3 = (int *)calloc(rows * cols, sizeof(int));
        if (matrix == NULL || data3 == NULL) {
            free(matrix); free(data3);
            printf("n/a"); return 0;
        }
        for (int i = 0; i < rows; i++) {
            matrix[i] = data3 + i * cols;
        }
    } else if (type == 4) {
        matrix = (int **)malloc(rows * sizeof(int *));
        if (matrix == NULL) { printf("n/a"); return 0; }
        data4 = (int *)malloc(rows * cols * sizeof(int));
        if (data4 == NULL) {
            free(matrix);
            printf("n/a"); return 0;
        }
        for (int i = 0; i < rows; i++) {
            matrix[i] = data4 + i * cols;
        }
    }

    if (input_matrix(matrix, rows, cols) == 0) {
        // Выделяем статические массивы под результаты (макс. размер 100 по ТЗ)
        int rows_max[ST_MAX];
        int cols_min[ST_MAX];

        find_rows_max(matrix, rows, cols, rows_max);
        find_cols_min(matrix, rows, cols, cols_min);

        output_matrix(matrix, rows, cols);
        printf("\n");
        output_array(rows_max, rows);
        printf("\n");
        output_array(cols_min, cols); // Последняя строка вывода, без \n на конце
    } else {
        printf("n/a");
    }

    free_matrix(matrix, rows, type, data3, data4);
    return 0;
}

int input_menu(int *type) {
    if (scanf("%d", type) != 1 || *type < 1 || *type > 4) {
        return 1;
    }
    return 0;
}

int input_dimensions(int *rows, int *cols) {
    if (scanf("%d %d", rows, cols) != 2 || *rows <= 0 || *cols <= 0) {
        return 1;
    }
    return 0;
}

int input_matrix(int **matrix, int rows, int cols) {
    for (int i = 0; i < rows; i++) {
        for (int j = 0; j < cols; j++) {
            if (scanf("%d", &matrix[i][j]) != 1) {
                return 1;
            }
        }
    }
    char ctrl;
    if (scanf("%c", &ctrl) == 1 && ctrl != '\n' && ctrl != ' ' && ctrl != '\t') {
        return 1;
    }
    return 0;
}

void output_matrix(int **matrix, int rows, int cols) {
    for (int i = 0; i < rows; i++) {
        for (int j = 0; j < cols; j++) {
            printf("%d%s", matrix[i][j], (j < cols - 1) ? " " : "");
        }
        if (i < rows - 1) {
            printf("\n");
        }
    }
}

// Поиск максимального элемента в каждой строке
void find_rows_max(int **matrix, int rows, int cols, int *res) {
    for (int i = 0; i < rows; i++) {
        int max = matrix[i][0];
        for (int j = 1; j < cols; j++) {
            if (matrix[i][j] > max) {
                max = matrix[i][j];
            }
        }
        *(res + i) = max;
    }
}

// Поиск минимального элемента в каждом столбце
void find_cols_min(int **matrix, int rows, int cols, int *res) {
    for (int j = 0; j < cols; j++) {
        int min = matrix[0][j];
        for (int i = 1; i < rows; i++) {
            if (matrix[i][j] < min) {
                min = matrix[i][j];
            }
        }
        *(res + j) = min;
    }
}

// Универсальный вывод одномерного массива через пробел без \n на конце
void output_array(const int *arr, int len) {
    for (int i = 0; i < len; i++) {
        printf("%d%s", *(arr + i), (i < len - 1) ? " " : "");
    }
}

void free_matrix(int **matrix, int rows, int type, int *data3, int *data4) {
    if (matrix == NULL) return;
    
    if (type == 2) {
        for (int i = 0; i < rows; i++) {
            free(matrix[i]);
        }
        free(matrix);
    } else if (type == 3) {
        free(data3);
        free(matrix);
    } else if (type == 4) {
        free(data4);
        free(matrix);
    }
}
